APP_NAME=Spotify Review Discovery Engine
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Leave unset to use config.py default SQLite path
# DATABASE_URL=sqlite:///C:/absolute/path/to/spotify-review-engine/data/spotify_review_engine.db

REVIEWS_CSV_PATH=data/raw/spotify_reviews.csv

LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-3.1-flash-lite,gemini-3.5-flash,gemini-2.5-flash-lite,gemini-3-flash



LOG_LEVEL=INFO
